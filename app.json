{
  "expo": {
    "name": "카성비",
    "slug": "cafficiency",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ic_launcher.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/ic_launcher.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ic_launcher.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/images/ic_launcher.png",
      "bundler": "metro",
      "output": "static"
    }
  }
}
